# Runtime artifacts — per-session JSONL audit logs.
# Both locations are runtime output:
#   - artifacts/runs/{session_id}/events.jsonl  (Phase 10 default)
#   - apps/artifacts/runs/{session_id}/events.jsonl  (legacy, pre-Phase 10)
# Keep the sample workflow as a reference, but never commit live session data.
artifacts/runs/*
apps/artifacts/runs/*
!artifacts/runs/.gitkeep
!artifacts/runs/sample_workflow.json
!apps/artifacts/runs/.gitkeep

# Logs
logs/

# SQLite (created at runtime by Phase 2)
*.db
*.sqlite
*.sqlite3
apps/backend/windagent.db
apps/backend/windagent.db-journal

# OS
desktop.ini

# Environment secrets (if any)
.env
.env.local
.env.*.local

# Vendored third-party sources. The README.md + .gitkeep are kept so
# the directory structure is visible; the actual upstream checkouts
# (external/Agent-S/) are populated by scripts/setup_agent_s3.ps1 and
# must NOT be committed.
external/**/.git/
external/Agent-S/gui_agents/
external/Agent-S/agent_s/
external/Agent-S/setup.py
external/Agent-S/pyproject.toml
external/Agent-S/README.md
external/Agent-S/LICENSE*
external/Agent-S/.gitignore
